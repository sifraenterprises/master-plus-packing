# Grewal Desktop Automation Worker
# Copy to .env on the assigned office desktop. Never commit the completed .env file.
API_BASE_URL=https://www.grewalengineeringworks.com/api
DESKTOP_WORKER_TOKEN=
WORKER_NAME=UNCONFIGURED

# TAFE credentials stay only on the office desktop.
TAFE_PORTAL_URL=
TAFE_USERNAME=
TAFE_PASSWORD=

# Keep test mode enabled until a supervised validation has passed.
TEST_MODE=true
HEADLESS=false
POLL_INTERVAL_SECONDS=10
HEARTBEAT_INTERVAL_SECONDS=30
